# ===== OpenAI =====
# Bắt buộc: điền API key của bạn
OPENAI_API_KEY=
# (tuỳ chọn) base url nếu dùng proxy / Azure-compatible endpoint / comment nếu openAI API
# OPENAI_BASE_URL=

# ===== Logging =====
# INFO sẽ in các dòng RAG_FLOW gồm node, thời gian gọi LLM/inference/retrieval.
LOG_LEVEL=INFO

# ===== Models (tự điền tên model bạn muốn dùng) =====
# Model trả lời cuối (chất lượng cao)
LLM_MODEL=gpt-5.4-mini
# Model rẻ cho router / phân rã / distill (tối ưu chi phí)
LLM_MODEL_FAST=gpt-4o-mini
# Embedding model
EMBED_MODEL=text-embedding-3-small
# Để trống -> tự suy ra dim từ lần embed đầu tiên (turbovec lazy dim)
EMBED_DIM=

# ===== Retrieval =====
BM25_TOP_K=30
DENSE_TOP_K=30
RRF_K=60
RERANK_TOP_N=15
FINAL_TOP_K=10
USE_RERANKER=true
# RERANKER_TYPE: auto (jina if key, else local), jina, local
RERANKER_TYPE=auto
# Jina API (fast, multilingual, ~200ms/15 pairs) — KHUYÊN DÙNG
JINA_API_KEY=
RERANKER_MODEL=jina-reranker-v3
# Local reranker (miễn phí, nhưng chậm trên CPU ~3s/15 pairs)
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
USE_HYDE=false   # not yet implemented — placeholder for future HyDE support

# ===== Agent =====
MAX_REPLAN_ITERS=3
MAX_ANSWER_REGENERATIONS=1
ENABLE_REPLAN=true
ENABLE_SUFFICIENCY=true
# Global verify kill-switch. Per-route flags below take effect only when this is true.
ENABLE_ANSWER_VERIFY=true
# Verify grounding for simple route (default off — streams directly, lower hallucination risk)
ENABLE_ANSWER_VERIFY_SIMPLE=false
# Verify grounding for complex/multi-hop route (default on — synthesis more prone to errors)
ENABLE_ANSWER_VERIFY_COMPLEX=true
# Max context chunks fed to LLM for complex queries (each may be an RSE segment)
COMPLEX_CTX_LIMIT=8
TURBOVEC_BIT_WIDTH=4

# ===== Memory / Summarization =====
ENABLE_SUMMARIZATION=true
# Số tin nhắn tối thiểu trong session trước khi kích hoạt tóm tắt
SUMMARY_THRESHOLD=12
# Số tin nhắn gần nhất luôn giữ nguyên (không tóm tắt)
HISTORY_WINDOW=6
# Model dùng để tóm tắt (để trống -> dùng LLM_MODEL_FAST)
SUMMARY_MODEL=gpt-4o-mini

# ===== Ingestion / Parsing =====
# off  -> chỉ trích xuất cục bộ (PyMuPDF), không gọi LLM (rẻ, nhanh nhất)
# auto -> chỉ dùng VLM cho trang scan/ảnh (không có text) — mặc định
# on   -> luôn dùng VLM transcribe (chính xác nhất cho PDF khó, tốn token khi nạp)
VLM_PARSE=auto
VLM_MODEL=gpt-4o-mini
# Kích thước chunk (ký tự) và độ chồng lấn
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP=200

# ===== Storage =====
STORAGE_DIR=storage

# ===== Reducto Parser =====
# off      -> PyMuPDF + VLM (miễn phí, local)
# default  -> Reducto default (1 credit/page, chất lượng tốt) — KHUYÊN DÙNG
# agentic  -> Reducto agentic (2 credits/page, VLM text+table review, chất lượng tốt nhất)
REDUCTO_PARSE=agentic
REDUCTO_API_KEY=
REDUCTO_CHUNK_MODE=page_sections
REDUCTO_CHUNK_SIZE=1200
REDUCTO_FILTER_BLOCKS=Header,Footer,Page Number
REDUCTO_TABLE_FORMAT=dynamic

# ===== MinerU Parser (local OCR, heavy ML models) =====
# Cài MinerU vào cùng venv backend:
#   uv pip install "mineru[pipeline]"
# Hoặc chỉ định đường dẫn qua MINERU_CMD.
# Device auto-detect: CUDA → MPS → CPU. Override bằng MINERU_DEVICE_MODE.
#
# off   -> Không dùng MinerU (mặc định)
# on    -> Luôn dùng MinerU, báo lỗi nếu thất bại
# auto  -> Thử MinerU, fallback về PyMuPDF nếu lỗi
MINERU_PARSE=off
# MINERU_CMD=   # để trống = tự detect: .venv/bin/mineru → mineru trong PATH
# MINERU_DEVICE_MODE=   # để trống = auto (cuda→mps→cpu), hoặc ghi đè: cpu / cuda / mps

# ===== Context Enrichment (4-tier CCH — giống dsRAG auto_context) =====
# Tier 2 – Document summary: 1 câu tóm tắt toàn tài liệu, prepend vào embed text mỗi chunk.
# Chi phí: ~$0.0002/tài liệu (gpt-4o-mini). Tắt nếu không muốn tốn LLM call lúc ingest.
ENABLE_DOC_SUMMARY=true
# Số ký tự tài liệu gửi cho LLM (~24000 chars ≈ 6000 tokens, bao quát tài liệu dài)
DOC_SUMMARY_CHARS=24000
# Model generate summary (để trống -> dùng LLM_MODEL_FAST)
# DOC_SUMMARY_MODEL=

# Tier 4 – Section summaries: 1 câu/section, gọi LLM song song cho mỗi section.
# Chi phí: ~$0.001/tài liệu cho 10-20 section. Tắt nếu muốn tiết kiệm.
ENABLE_SECTION_SUMMARY=true
# Số ký tự nội dung section gửi cho LLM để tóm tắt
SECTION_SUMMARY_CHARS=2000

# ===== RSE (Relevant Segment Extraction) =====
# RSE thay thế top-k chunks bằng các đoạn liên tục (segment) tốt hơn.
# Thuật toán max-subarray trên score array của chunk, ~5ms, không tốn LLM.
USE_RSE=true
# Penalty cho chunk không được retrieve (0.0-1.0). Tăng = segment chặt chẽ hơn.
RSE_IRRELEVANT_PENALTY=0.2
# Số chunk tối đa trong 1 segment
RSE_MAX_SEGMENT_CHUNKS=15
# Tổng số chunk tối đa qua tất cả segment trả về
RSE_OVERALL_MAX_CHUNKS=30
# Mở rộng cửa sổ RSE về phía trước min_idx (để bắt context intro trước hit đầu tiên)
RSE_WINDOW_EXTENSION=2
# Nhân score RSE theo độ dài chunk (chunk ngắn = ít trọng số, giảm anchor trên header nhỏ)
RSE_CHUNK_LENGTH_ADJUSTMENT=true
# Bỏ qua chunk < N chars khi index BM25/vector (vẫn lưu DB cho RSE bridge)
MIN_CHUNK_CHARS=50
