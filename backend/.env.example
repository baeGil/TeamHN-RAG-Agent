# ===== OpenAI =====
# Bắt buộc: điền API key của bạn
OPENAI_API_KEY=
# (tuỳ chọn) base url nếu dùng proxy / Azure-compatible endpoint / để trống nếu openAI API
OPENAI_BASE_URL=

# ===== Models (tự điền tên model bạn muốn dùng) =====
# Model trả lời cuối (chất lượng cao)
LLM_MODEL=gpt-5.4-mini
# Model rẻ cho router / phân rã / distill (tối ưu chi phí)
LLM_MODEL_FAST=gpt-4o-mini
# Embedding model
EMBED_MODEL=text-embedding-3-small
# Để trống -> tự suy ra dim từ lần embed đầu tiên (turbovec lazy dim)
EMBED_DIM=

# ===== Retrieval =====
BM25_TOP_K=50
DENSE_TOP_K=50
RRF_K=60
RERANK_TOP_N=10
FINAL_TOP_K=5
USE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
USE_HYDE=false

# ===== Agent =====
MAX_REPLAN_ITERS=3
TURBOVEC_BIT_WIDTH=4

# ===== Storage =====
STORAGE_DIR=storage
